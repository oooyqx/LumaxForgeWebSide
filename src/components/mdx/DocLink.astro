---
type Props = {
  href: string;
  label: string;
};

const { href, label } = Astro.props as Props;
const external = href.startsWith("http://") || href.startsWith("https://");
---

<a
  class="doc-link"
  href={href}
  target={external ? "_blank" : undefined}
  rel={external ? "noreferrer" : undefined}
>
  {label}
</a>
