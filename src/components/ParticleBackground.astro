---
// 粒子背景组件 - 发光球体从下往上飘动
const particleImages = [
  '/particles/par (1).png',
  '/particles/par (2).png',
  '/particles/par (3).png',
  '/particles/par (4).png',
  '/particles/par (5).png',
  '/particles/par (6).png',
];
---

<div class="particle-background" id="particle-bg">
</div>

<style>
  .particle-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .particle-background :global(.particle) {
    position: absolute;
    pointer-events: none;
    will-change: transform, opacity;
  }
</style>

<script define:vars={{ particleImages }}>
  const container = document.getElementById('particle-bg');
  if (container) {
    const particleCount = 20;
    const particles = [];

    function createParticle() {
      const particle = document.createElement('img');
      particle.className = 'particle';
      particle.src = particleImages[Math.floor(Math.random() * particleImages.length)];
      
      const size = 20 + Math.random() * 40;
      particle.style.width = size + 'px';
      particle.style.height = size + 'px';
      
      resetParticle(particle, true);
      container.appendChild(particle);
      particles.push({
        el: particle,
        x: parseFloat(particle.style.left),
        y: parseFloat(particle.style.top),
        speed: 0.3 + Math.random() * 0.7,
        wobbleSpeed: 0.5 + Math.random() * 1,
        wobbleAmount: 10 + Math.random() * 20,
        phase: Math.random() * Math.PI * 2,
        opacity: 0,
        fadeIn: true,
        maxOpacity: 0.3 + Math.random() * 0.5
      });
    }

    function resetParticle(particle, initial) {
      const x = Math.random() * 100;
      const y = initial ? Math.random() * 100 : 105;
      particle.style.left = x + '%';
      particle.style.top = y + '%';
      particle.style.opacity = '0';
      return { x, y };
    }

    function animate() {
      particles.forEach((p, index) => {
        p.y -= p.speed * 0.1;
        p.phase += p.wobbleSpeed * 0.01;
        const wobbleX = Math.sin(p.phase) * p.wobbleAmount * 0.1;
        
        if (p.y < -10) {
          const pos = resetParticle(p.el, false);
          p.x = pos.x;
          p.y = pos.y;
          p.opacity = 0;
          p.fadeIn = true;
          p.maxOpacity = 0.3 + Math.random() * 0.5;
        }
        
        if (p.fadeIn) {
          p.opacity += 0.005;
          if (p.opacity >= p.maxOpacity) {
            p.opacity = p.maxOpacity;
            p.fadeIn = false;
          }
        } else if (p.y < 20) {
          p.opacity = Math.max(0, p.opacity - 0.008);
        }
        
        p.el.style.top = p.y + '%';
        p.el.style.left = (p.x + wobbleX) + '%';
        p.el.style.opacity = p.opacity.toString();
      });
      
      requestAnimationFrame(animate);
    }

    for (let i = 0; i < particleCount; i++) {
      createParticle();
    }
    
    animate();
  }
</script>
