---
// 粒子背景组件 - 发光球体从四周加速冲向Logo
const particleImages = [
  '/particles/par (1).png',
  '/particles/par (2).png',
  '/particles/par (3).png',
  '/particles/par (4).png',
  '/particles/par (5).png',
  '/particles/par (6).png',
];
---

<div class="particle-background" id="particle-bg">
</div>

<style>
  .particle-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .particle-background :global(.particle) {
    position: absolute;
    pointer-events: none;
    will-change: transform, opacity, filter;
  }
</style>

<script define:vars={{ particleImages }}>
  const container = document.getElementById('particle-bg');
  
  if (container) {
    const particleCount = 25;
    const particles = [];
    const particleSize = 14;

    function getLogoCenter() {
      const logoEl = document.getElementById('header-logo');
      if (logoEl) {
        const rect = logoEl.getBoundingClientRect();
        return {
          x: rect.left + rect.width / 2,
          y: rect.top + rect.height * 0.25 + 30
        };
      }
      return { x: window.innerWidth / 2, y: 98 };
    }

    function getRandomEdgePosition() {
      const edge = Math.floor(Math.random() * 4);
      const w = window.innerWidth;
      const h = window.innerHeight;
      const margin = 50;
      
      switch (edge) {
        case 0: return { x: Math.random() * w, y: -margin };
        case 1: return { x: Math.random() * w, y: h + margin };
        case 2: return { x: -margin, y: Math.random() * h };
        case 3: return { x: w + margin, y: Math.random() * h };
        default: return { x: Math.random() * w, y: h + margin };
      }
    }

    function createParticle() {
      const particle = document.createElement('img');
      particle.className = 'particle';
      particle.src = particleImages[Math.floor(Math.random() * particleImages.length)];
      particle.style.width = particleSize + 'px';
      particle.style.height = particleSize + 'px';
      particle.style.opacity = '0';
      
      container.appendChild(particle);
      
      const p = resetParticleData();
      p.el = particle;
      particles.push(p);
    }

    function resetParticleData() {
      const start = getRandomEdgePosition();
      const target = getLogoCenter();
      const dx = target.x - start.x;
      const dy = target.y - start.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const dirX = dx / dist;
      const dirY = dy / dist;
      
      return {
        el: null,
        x: start.x,
        y: start.y,
        dirX: dirX,
        dirY: dirY,
        speed: 0.3 + Math.random() * 0.6,
        acceleration: 0.02 + Math.random() * 0.02,
        targetX: target.x,
        targetY: target.y,
        opacity: 0,
        phase: 'fadein',
        maxOpacity: 0.5 + Math.random() * 0.4,
        delay: Math.random() * 3000
      };
    }

    function resetParticle(p) {
      const data = resetParticleData();
      p.x = data.x;
      p.y = data.y;
      p.dirX = data.dirX;
      p.dirY = data.dirY;
      p.speed = data.speed;
      p.acceleration = data.acceleration;
      p.targetX = data.targetX;
      p.targetY = data.targetY;
      p.opacity = 0;
      p.phase = 'fadein';
      p.maxOpacity = data.maxOpacity;
      p.delay = data.delay;
    }

    let lastTime = performance.now();
    
    function animate(currentTime) {
      const deltaTime = Math.min((currentTime - lastTime) / 16.67, 3);
      lastTime = currentTime;
      
      particles.forEach((p) => {
        if (p.delay > 0) {
          p.delay -= deltaTime * 16.67;
          return;
        }

        p.speed += p.acceleration * deltaTime;
        p.x += p.dirX * p.speed * deltaTime;
        p.y += p.dirY * p.speed * deltaTime;
        
        const dx = p.targetX - p.x;
        const dy = p.targetY - p.y;
        const distToTarget = Math.sqrt(dx * dx + dy * dy);
        
        if (p.phase === 'fadein') {
          p.opacity += 0.15 * deltaTime;
          if (p.opacity >= p.maxOpacity) {
            p.opacity = p.maxOpacity;
            p.phase = 'visible';
          }
        }
        
        if (distToTarget < 80) {
          p.phase = 'fadeout';
        }
        
        if (p.phase === 'fadeout') {
          p.opacity -= 0.2 * deltaTime;
          if (p.opacity <= 0) {
            p.opacity = 0;
            resetParticle(p);
          }
        }
        
        const blurAmount = Math.min(p.speed * 0.8, 12);
        const angle = Math.atan2(p.dirY, p.dirX) * 180 / Math.PI;
        
        p.el.style.left = p.x + 'px';
        p.el.style.top = p.y + 'px';
        p.el.style.opacity = p.opacity.toString();
        p.el.style.filter = `blur(${blurAmount * 0.15}px) drop-shadow(${-p.dirX * blurAmount}px ${-p.dirY * blurAmount}px ${blurAmount}px rgba(120, 180, 255, 0.6))`;
        p.el.style.transform = `translate(-50%, -50%)`;
      });
      
      requestAnimationFrame(animate);
    }

    // 延迟初始化，确保 Logo 已渲染
    setTimeout(() => {
      for (let i = 0; i < particleCount; i++) {
        createParticle();
      }
      requestAnimationFrame(animate);
    }, 100);
    
    window.addEventListener('resize', () => {
      particles.forEach(p => {
        const target = getLogoCenter();
        p.targetX = target.x;
        p.targetY = target.y;
      });
    });
  }
</script>
