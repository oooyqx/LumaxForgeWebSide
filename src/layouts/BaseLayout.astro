---
import "../styles/global.css";
import { LANGS, TEXT, type Lang } from "../lib/i18n";
import ParticleBackground from "../components/ParticleBackground.astro";

type Props = {
  lang: Lang;
  title: string;
  description?: string;
  bodyClass?: string;
};

const { lang, title, description, bodyClass } = Astro.props as Props;
const t = TEXT[lang];
const path = Astro.url.pathname;
const isPathForLang = (candidateLang: Lang) => {
  const parts = path.split("/").filter(Boolean);
  if (parts.length === 0) return `/${candidateLang}`;
  if (LANGS.includes(parts[0] as Lang)) {
    parts[0] = candidateLang;
    return `/${parts.join("/")}`;
  }
  return `/${candidateLang}/${parts.join("/")}`;
};
const navItems = [
  { href: `/${lang}`, label: t.navHome },
  { href: `/${lang}/asset-store`, label: t.navAssetStore },
  { href: `/${lang}/docs`, label: t.navDocs }
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/png" href="/brand/lumaxforge-logo.png" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={Astro.url.href} />
  </head>
  <body class={bodyClass}>
    <ParticleBackground />
    <header class="site-header">
      <div class="container site-header-inner">
        <a class="brand" href={`/${lang}`} aria-label="LumaxForge Home">
          <div class="brand-logo-wrapper">
            <img class="brand-logo" src="/brand/lumaxforge-logo.png" width="36" height="36" alt="LumaxForge logo" id="header-logo" />
            <img class="brand-logo-highlight" src="/brand/lumaxforge-logo-highlight.png" width="36" height="36" alt="" />
          </div>
          <img
            class="brand-wordmark"
            src="/brand/lumaxforge-wordmark.png"
            width="168"
            height="28"
            alt="LumaxForge"
          />
        </a>
        <nav class="main-nav">
          {
            navItems.map((item) => (
              <a href={item.href} aria-current={path === item.href ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
        </nav>
        <div class="lang-switch">
          {
            LANGS.map((l) => (
              <a href={isPathForLang(l)} aria-current={String(l === lang)}>
                {l.toUpperCase()}
              </a>
            ))
          }
        </div>
      </div>
    </header>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="container">© {new Date().getFullYear()} LumaxForgeLLC. Built with Astro, deployed on Cloudflare Pages.</div>
    </footer>
  </body>
</html>
