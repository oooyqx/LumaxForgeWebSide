---
import { getCollection } from "astro:content";
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import { TEXT, type Lang } from "../../../../../lib/i18n";

export async function getStaticPaths() {
  const entries = await getCollection("manuals");
  return entries.map((entry) => ({
    params: {
      lang: entry.data.lang,
      slug: entry.data.productSlug,
      chapter: entry.data.chapterSlug
    },
    props: { entry }
  }));
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string; chapter: string };
const { entry } = Astro.props;
const t = TEXT[lang];
const chapters = (await getCollection("manuals", ({ data }) => data.lang === lang && data.productSlug === slug)).sort(
  (a, b) => a.data.order - b.data.order
);
const { Content } = await entry.render();

const groupTitles: Record<Lang, Record<string, string>> = {
  zh: {
    "00": "上手与工作流",
    "01": "编辑器工作流",
    "02": "编辑器面板",
    "03": "Series 配置",
    "04": "参考与 FAQ",
    "05": "更新与规划"
  },
  en: {
    "00": "Getting Started",
    "01": "Editor Workflow",
    "02": "Editor Panels",
    "03": "Series Setup",
    "04": "Reference & FAQ",
    "05": "Updates"
  }
};

const getGroupKey = (chapterSlug: string) => chapterSlug.split("_")[0];
const groups = Object.entries(
  chapters.reduce<Record<string, typeof chapters>>((acc, ch) => {
    const k = getGroupKey(ch.data.chapterSlug);
    (acc[k] ||= []).push(ch);
    return acc;
  }, {})
).sort(([a], [b]) => a.localeCompare(b));
---

<BaseLayout
  lang={lang}
  title={`${entry.data.title} | ${t.manualTitle} | ${t.siteName}`}
  description={entry.data.title}
  bodyClass={slug === "easy-chart-lit" ? "docs-theme" : undefined}
>
  <section class="hero">
    <h1>{entry.data.title}</h1>
    <p>
      {slug} · {t.manualTitle}
    </p>
    <div class="card-actions">
      <a class="btn" href={`/${lang}/products/${slug}`}>{t.backToProduct}</a>
      <a class="btn" href={`/${lang}/products/${slug}/manual`}>{t.chapterList}</a>
    </div>
  </section>

  <div class="manual-layout">
    <aside class="panel chapter-nav">
      <h3>{t.chapterList}</h3>
      <nav class="chapter-tree" aria-label={t.chapterList}>
        {groups.map(([groupKey, items]) => {
          const isOpen = items.some((c) => c.id === entry.id);
          const label = groupTitles[lang]?.[groupKey] ?? groupKey;
          return (
            <details class="chapter-group" open={isOpen}>
              <summary class="chapter-group-title">{label}</summary>
              <div class="chapter-group-items">
                {items.map((chapter) => (
                  <a
                    class="chapter-link"
                    href={`/${lang}/products/${slug}/manual/${chapter.data.chapterSlug}`}
                    aria-current={chapter.id === entry.id ? "page" : undefined}
                  >
                    {chapter.data.title}
                  </a>
                ))}
              </div>
            </details>
          );
        })}
      </nav>
    </aside>

    <article class="panel prose">
      <Content />
    </article>
  </div>
</BaseLayout>
