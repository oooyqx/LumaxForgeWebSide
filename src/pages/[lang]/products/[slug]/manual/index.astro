---
import { getCollection } from "astro:content";
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import { TEXT, type Lang } from "../../../../../lib/i18n";

export async function getStaticPaths() {
  const entries = await getCollection("manuals");
  const keys = new Set(entries.map((entry) => `${entry.data.lang}::${entry.data.productSlug}`));
  return Array.from(keys).map((key) => {
    const [lang, slug] = key.split("::");
    return { params: { lang, slug } };
  });
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const t = TEXT[lang];
const chapters = (await getCollection("manuals", ({ data }) => data.lang === lang && data.productSlug === slug)).sort(
  (a, b) => a.data.order - b.data.order
);

if (chapters.length === 0) {
  throw new Error(`No manual chapters found for ${lang}/${slug}`);
}

const first = chapters[0];

const groupTitles: Record<Lang, Record<string, string>> = {
  zh: {
    "00": "上手与工作流",
    "01": "编辑器工作流",
    "02": "编辑器面板",
    "03": "Series 配置",
    "04": "参考与 FAQ",
    "05": "更新与规划"
  },
  en: {
    "00": "Getting Started",
    "01": "Editor Workflow",
    "02": "Editor Panels",
    "03": "Series Setup",
    "04": "Reference & FAQ",
    "05": "Updates"
  }
};

const getGroupKey = (chapterSlug: string) => chapterSlug.split("_")[0];
const groups = Object.entries(
  chapters.reduce<Record<string, typeof chapters>>((acc, ch) => {
    const k = getGroupKey(ch.data.chapterSlug);
    (acc[k] ||= []).push(ch);
    return acc;
  }, {})
).sort(([a], [b]) => a.localeCompare(b));
---

<BaseLayout
  lang={lang}
  title={`${slug} ${t.manualTitle} | ${t.siteName}`}
  description={t.manualTitle}
  bodyClass={slug === "easy-chart-lit" ? "docs-theme" : undefined}
>
  <section class="hero">
    <h1>{slug} {t.manualTitle}</h1>
    <p>{t.chapterList}</p>
    <div class="card-actions">
      <a class="btn" href={`/${lang}/products/${slug}`}>{t.backToProduct}</a>
    </div>
  </section>

  <div class="manual-layout">
    <aside class="panel chapter-nav">
      <h3>{t.chapterList}</h3>
      <nav class="chapter-tree" aria-label={t.chapterList}>
        {groups.map(([groupKey, items], idx) => {
          const label = groupTitles[lang]?.[groupKey] ?? groupKey;
          return (
            <details class="chapter-group" open={idx === 0}>
              <summary class="chapter-group-title">{label}</summary>
              <div class="chapter-group-items">
                {items.map((chapter) => (
                  <a class="chapter-link" href={`/${lang}/products/${slug}/manual/${chapter.data.chapterSlug}`}>
                    {chapter.data.title}
                  </a>
                ))}
              </div>
            </details>
          );
        })}
      </nav>
    </aside>

    <article class="panel prose">
      <p>
        This is the manual chapter index. Open the first chapter:
        <a href={`/${lang}/products/${slug}/manual/${first.data.chapterSlug}`}> {first.data.title}</a>
      </p>
    </article>
  </div>
</BaseLayout>
