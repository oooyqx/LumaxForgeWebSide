---
import { getCollection } from "astro:content";
import SolutionCard from "../../../components/SolutionCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { LANGS, TEXT, type Lang } from "../../../lib/i18n";

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = TEXT[lang];
const solutions = (await getCollection("solutions", ({ data }) => data.lang === lang)).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
---

<BaseLayout lang={lang} title={`${t.siteName} | ${t.navProducts}`} description={t.productsSubtitle}>
  <section class="hero">
    <h1>{t.productsTitle}</h1>
    <p>{t.productsSubtitle}</p>
  </section>
  {solutions.length > 0 ? (
    <div class="products-grid">
      {solutions.map((solution) => <SolutionCard lang={lang} solution={solution} />)}
    </div>
  ) : (
    <section class="panel">
      <p>{t.productsEmpty}</p>
    </section>
  )}
</BaseLayout>
