---
import { getCollection } from "astro:content";
import ProductCard from "../../../components/ProductCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { LANGS, TEXT, type Lang } from "../../../lib/i18n";

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = TEXT[lang];
const products = (await getCollection("products", ({ data }) => data.lang === lang)).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
---

<BaseLayout lang={lang} title={`${t.siteName} | ${t.navProducts}`} description={t.productsSubtitle}>
  <section class="hero">
    <h1>{t.productsTitle}</h1>
    <p>{t.productsSubtitle}</p>
  </section>
  <div class="products-grid">
    {products.map((product) => <ProductCard lang={lang} product={product} />)}
  </div>
</BaseLayout>
