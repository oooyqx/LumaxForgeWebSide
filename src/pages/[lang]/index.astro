---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { listAssetsDataFolders } from "../../lib/assetsdata";
import { LANGS, TEXT, type Lang } from "../../lib/i18n";

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = TEXT[lang];
const assets = listAssetsDataFolders();
---

<BaseLayout lang={lang} title={`${t.siteName} | ${t.navHome}`} description={t.assetStoreSubtitle}>
  <section>
    <div class="product-carousel-head">
      <div>
        <h2 class="product-carousel-title">{t.assetStoreTitle}</h2>
        <p class="product-carousel-subtitle">{t.assetStoreSubtitle}</p>
      </div>
      <a class="btn" href={`/${lang}/asset-store`}>
        {t.details}
      </a>
    </div>
    {assets.length > 0 ? (
      <div class="products-grid">
        {assets.slice(0, 8).map((asset) => (
          <a class="asset-card" href={`/${lang}/asset-store/${asset.slug}`} title={asset.data.descriptionText || asset.data.category || asset.folderName}>
            <div class="asset-card-image-wrapper">
              {asset.data.cardImage ? (
                <img class="asset-card-image" src={asset.data.cardImage} alt={asset.title} loading="lazy" decoding="async" />
              ) : (
                <div class="asset-card-placeholder"></div>
              )}
              <h3 class="asset-card-title">{asset.title}</h3>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <section class="panel">
        <p>{t.assetStoreEmpty}</p>
      </section>
    )}
  </section>
</BaseLayout>
